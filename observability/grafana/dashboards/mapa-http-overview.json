{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Mapa · HTTP Overview",
  "uid": "mapa-http-overview",
  "tags": ["mapa", "http", "errors", "latency"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "tier",
        "label": "Tier",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${ds}" },
        "query": "label_values(http_requests_total, tier)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "route",
        "label": "Route",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${ds}" },
        "query": "label_values(http_requests_total{tier=~\"$tier\"}, route)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "ds",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Req/s (total)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{tier=~\"$tier\"}[5m]))", "legendFormat": "req/s" }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate % (5xx)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{tier=~\"$tier\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{tier=~\"$tier\"}[5m])), 1)",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p99 latency (all)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{tier=~\"$tier\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx count (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sum(increase(http_errors_total{tier=~\"$tier\",status_code=~\"5..\"}[1h]))", "legendFormat": "5xx" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests/s by status code",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(http_requests_total{tier=~\"$tier\"}[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p90 / p99 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{tier=~\"$tier\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket{tier=~\"$tier\"}[5m])) by (le))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{tier=~\"$tier\"}[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "table",
      "title": "5xx by route (top offenders)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [
        {
          "expr": "topk(20, sum by (route, status_code) (rate(http_requests_total{tier=~\"$tier\",status_code=~\"5..\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{route}} {{status_code}}"
        }
      ]
    },
    {
      "type": "table",
      "title": "p99 latency by route (slowest endpoints)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "topk(20, histogram_quantile(0.99, sum by (le, route) (rate(http_request_duration_seconds_bucket{tier=~\"$tier\",route=~\"$route\"}[5m]))))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests/s by route (top 10)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [
        {
          "expr": "topk(10, sum by (route) (rate(http_requests_total{tier=~\"$tier\"}[5m])))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "4xx by route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{tier=~\"$tier\",status_code=~\"4..\"}[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
