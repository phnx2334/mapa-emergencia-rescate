# Plantilla del env del stack de OBSERVABILIDAD (VPS dedicado).
# Copia a .observability.env (GITIGNORED, en la RAÍZ) y rellena. Es un archivo
# .env-style para subir con ./upload-github-secrets.sh -f .observability.env -e observability
# (igual que .env -> production-hetzner y .staging.env -> staging).
#
# El deploy (deploy-observability.yml) materializa el real desde los secrets
# per-key del environment `observability` y lo manda al VPS dedicado.

# --- Runtime del stack (van al contenedor) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cámbiame-por-uno-fuerte
GRAFANA_ROOT_URL=https://grafana-observability.terremotovenezuela.app
GRAFANA_DOMAIN=grafana-observability.terremotovenezuela.app
# Bearer token de PUSH (k3s -> obs). MISMO valor en la config de Alloy en k3s.
# Genera: openssl rand -hex 32
OBS_PUSH_TOKEN=genera-con-openssl-rand-hex-32

# --- Conexión SSH al VPS dedicado (solo para el workflow, NO van al contenedor) ---
# Auth por CLAVE (mapa-key), no password. La clave privada va como secret
# OBS_SSH_KEY en el environment.
OBS_HOST=167.233.197.13
OBS_USER=root
OBS_PROJECT_PATH=observability
