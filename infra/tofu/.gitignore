# Downloaded provider plugins — regenerated by `tofu init`, never commit.
.terraform/

# State + plan files. State lives in the remote S3 backend; if any local state
# appears it contains secrets in plaintext — never commit.
*.tfstate
*.tfstate.*
*.tfplan
crash.log

# Local var files with real values (terraform.tfvars.example IS committed).
terraform.tfvars
*.auto.tfvars

# Keep .terraform.lock.hcl tracked (provider version pin — like package-lock).
!.terraform.lock.hcl
